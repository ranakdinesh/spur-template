# ─── Core ─────────────────────────────────────────────────────────────────
APP_ENV=development
HTTP_ADDR=:8080
SPUR_APP_NAME=Spur

# ─── Postgres ─────────────────────────────────────────────────────────────
POSTGRES_DB=spur
POSTGRES_USER=spur
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://spur:changeme@postgres:5432/spur?sslmode=disable

# ─── Redis (rate limiting + token revocation) ─────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Identity ─────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
IDENTITY_JWT_SECRET=
IDENTITY_RSA_KEY_PATH=/app/keys/private.pem
IDENTITY_ISSUER=http://localhost:8080
IDENTITY_ACCESS_TTL=24h
IDENTITY_REFRESH_TTL=720h
IDENTITY_OTP_EXPIRY=2m
IDENTITY_OTP_MAX_ATTEMPTS=3

# OAuth2 (Fosite)
OAUTH_ISSUER=http://localhost:8080
# Generate: openssl rand -hex 32
FOSITE_GLOBAL_SECRET=
# Generate: uuidgen
AUTH_CLIENT_ID=
# Generate: openssl rand -hex 24
AUTH_CLIENT_SECRET=
JWT_PRIVATE_KEY_PATH=/app/keys/private.pem

# ─── Observability ────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ─── UI ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_THEME=spur
NEXT_PUBLIC_API_URL=http://localhost:8080
